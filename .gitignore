# Defensive: a top-level secrets.json is never expected (the in-repo
# git-crypt'd file lives at secrets/secrets.json and is opt-in via flake
# fallback; the rendered file lives at ~/.config/nixos-secrets/secrets.json
# which is outside the repo).
/secrets.json

# Flake lock backups
flake.lock-backup-*

# Nix build artifacts
result
result-*

# Worktree state files
.worktree-state.json
.worktree.lock
.dependabot-alert.json

# MCP config (project-level)
.mcp.json

# GrayMatter (curated knowledge migrated to .claude/docs/)
.graymatter/

# Claude Code plugin cache (reproducible from installed_plugins.json)
modules/apps/cli/claude-code/config/plugins/cache/

# Claudito conversation state
.claudito/

prompt.txt
.claude/settings.local.json
AGENTS.md
docs/superpowers/
__pycache__/
