# Defensive: nothing should ever land at the repo's old in-repo secrets
# locations. The rendered Nix-eval file is at ~/.config/nixos-secrets/
# secrets.json (outside the repo), and the Okular signature/initials PNGs
# are 1Password Documents fetched to ~/.kde/share/icons/ on demand.
/secrets.json
/secrets/secrets.json
/secrets/sg.png
/secrets/init.png

# Flake lock backups
flake.lock-backup-*

# Nix build artifacts
result
result-*

# Worktree state files
.worktree-state.json
.worktree.lock
.dependabot-alert.json

# MCP config (project-level)
.mcp.json

# GrayMatter (curated knowledge migrated to .claude/docs/)
.graymatter/

# Claude Code plugin cache (reproducible from installed_plugins.json)
modules/apps/cli/claude-code/config/plugins/cache/

prompt.txt
.claude/settings.local.json
AGENTS.md
docs/superpowers/
__pycache__/
