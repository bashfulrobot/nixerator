#!/usr/bin/env bash
# Auto-format staged Nix files with the repo formatter (`nix fmt` -> nixfmt-tree)
# and re-stage them, so no commit can introduce formatting drift — regardless of
# which editor, agent, or human produced the change.
#
# Install: `just setup-hooks` (sets core.hooksPath to .githooks for this clone).
set -euo pipefail

# Staged (added/copied/modified) .nix files only.
mapfile -t files < <(git diff --cached --name-only --diff-filter=ACM -- '*.nix')
[ "${#files[@]}" -eq 0 ] && exit 0

# Format from the repo root so `nix fmt` resolves the flake's formatter.
root="$(git rev-parse --show-toplevel)"
cd "$root"
nix fmt -- "${files[@]}"

# Re-stage whatever the formatter rewrote.
git add -- "${files[@]}"
