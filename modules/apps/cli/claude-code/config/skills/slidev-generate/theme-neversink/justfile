# Justfile for a Slidev deck. Run `just` to list recipes.

set quiet := true

# Default: list recipes.
default:
    @just --list --unsorted

# Install dependencies (run once after scaffolding, or after package.json changes).
install:
    pnpm install

# Live-reload dev server. Use this for authoring AND for presenting the talk.
#   Slideshow:  http://localhost:3030/
#   Presenter:  http://localhost:3030/presenter/   (notes, timer, next slide)
dev:
    pnpm dev

# Build static HTML to dist/ -- drop on any web host (Netlify, S3, GitHub Pages).
build:
    pnpm build

# Export deck as PDF (deck.pdf in cwd). Requires playwright-chromium.
pdf:
    pnpm export-pdf

# Export deck as PPTX (deck.pptx). NOTE: image-flatten -- text not selectable,
# no editable shapes. For an editable PPTX use the kong-pptx-build skill instead.
pptx:
    pnpm export-pptx

# Remove generated artifacts and node_modules.
clean:
    rm -rf dist deck.pdf deck.pptx node_modules .slidev
